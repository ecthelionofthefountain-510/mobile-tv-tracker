# Backend (server)
OPENAI_API_KEY=
# Optional: OpenAI-compatible base URL (for proxies / other providers)
OPENAI_BASE_URL=
# Optional: model name
OPENAI_MODEL=gpt-4o-mini
# Optional: restrict CORS (comma-separated)
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Optional: require this token in header x-ai-server-token
AI_SERVER_TOKEN=
# Optional: rate limit for /api/ai/pick
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# Frontend (Vite)
# Optional: override API base. Default is /api
VITE_AI_API_BASE=/api

# Supabase (frontend) — backend for auth + cloud data sync.
# Find these in your Supabase project: Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TMDb (frontend)
VITE_TMDB_API_KEY=
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
VITE_TMDB_LANGUAGE=en-US
VITE_APP_LOCALE=en-US
