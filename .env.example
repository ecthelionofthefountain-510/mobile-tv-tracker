# Backend (server)
OPENAI_API_KEY=
# Optional: OpenAI-compatible base URL (for proxies / other providers)
OPENAI_BASE_URL=
# Optional: model name
OPENAI_MODEL=gpt-4o-mini
# Optional: restrict CORS (comma-separated)
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Optional: require this token in header x-ai-server-token
AI_SERVER_TOKEN=
# Optional: rate limit for /api/ai/pick
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# Optional: require this token in header x-widget-server-token
# (or Authorization: Bearer <token>). Use a long random secret; set the SAME
# value in the Android widget config and the app's Widget Sync field.
WIDGET_SERVER_TOKEN=
# Optional: rate limit for /api/widget/upcoming
WIDGET_RATE_LIMIT_WINDOW_MS=60000
WIDGET_RATE_LIMIT_MAX=60
# Optional: widget response tuning
WIDGET_DEFAULT_LIMIT=6
WIDGET_TTL_SECONDS=1800
WIDGET_EMPTY_TTL_SECONDS=3600
WIDGET_ERROR_TTL_SECONDS=900
# Optional: server-side TMDb details cache ttl (ms)
WIDGET_TMDB_TTL_MS=21600000

# Widget profile persistence (production). When both are set, widget profiles
# are stored in Supabase (table: widget_profiles) instead of a local file, so
# the server is stateless and can be deployed to any host. Get the service-role
# key from Supabase: Settings → API → service_role (server-side secret — never
# expose to the frontend). Falls back to a local JSON file when unset.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional server aliases for TMDb config.
# If omitted, server also falls back to VITE_* values below.
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# Frontend (Vite)
# Optional: override API base. Default is /api
VITE_AI_API_BASE=/api

# Supabase (frontend) — backend for auth + cloud data sync.
# Find these in your Supabase project: Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TMDb (frontend)
VITE_TMDB_API_KEY=
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
VITE_TMDB_LANGUAGE=en-US
VITE_APP_LOCALE=en-US
